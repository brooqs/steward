# Spotify Integration
# Get your credentials from https://developer.spotify.com/dashboard
#
# Setup:
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add redirect URI: http://<your-steward-ip>:8080/api/spotify/callback
# 3. Fill in client_id and client_secret below, save, then click
#    "Connect Spotify" button in the admin panel — it handles OAuth2 automatically.
#
# Required scopes (handled automatically):
#   user-read-playback-state
#   user-modify-playback-state
#   user-read-currently-playing

enabled: false
client_id: ""
client_secret: ""
refresh_token: ""
